def calculeaza(a, b, operation):
    if operation == "+":
        return a + b
    elif operation == "-":
        return a - b
    elif operation == "*":
        return a * b
    elif operation == "/":
        if b != 0:
            return a / b
        else:
            return "division by zero is not allowed"
    else:
        return "Invalid operation"

print(calculeaza(10, 2, "+"))

###

def factorial(n):
    rezultat = 1
    for i in range(1, n + 1):
        rezultat *= i
    return rezultat

print(factorial(5))  # 120