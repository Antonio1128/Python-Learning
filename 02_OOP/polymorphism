class Dog:
    def speak(self):
        return "Bark"


class Cat:
    def speak(self):
        return "Meow"


class Cow:
    def speak(self):
        return "Moo"


def make_sound(animal):
    print(animal.speak())


def main():
    animals = [Dog(), Cat(), Cow()]

    for animal in animals:
        make_sound(animal)


if __name__ == "__main__":
    main()